{% extends 'base.html.twig' %}

{% block title %}Connexion | Forge des Heros{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="auth-panel">
            <div class="auth-copy">
                <p class="eyebrow">Connexion</p>
                <h1>Retrouve tes personnages et tes groupes.</h1>
                <p>Connecte-toi pour creer des fiches, rejoindre une equipe et reprendre ta campagne.</p>
            </div>

            <div class="auth-form-card">
                <h2>Se connecter</h2>

                {% if error %}
                    <div class="form-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form method="post">
                    <label for="username">Email</label>
                    <input type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="email" required autofocus>

                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="_password" autocomplete="current-password" required>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button class="button button-primary auth-submit" type="submit">Connexion</button>
                </form>

                <p class="auth-link">Pas encore de compte ? <a href="{{ path('app_register') }}">Inscription</a></p>
            </div>
        </section>
    </main>
{% endblock %}
