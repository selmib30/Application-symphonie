{% extends 'base.html.twig' %}

{% block title %}Nouvelle Race - Admin{% endblock %}

{% block body %}
    <head>
        {% block stylesheets %}
            {# Les styles ici seront présents sur TOUTES les pages #}
            <link rel="stylesheet" href="{{ asset('styles/admin_new.css') }}">
        {% endblock %}
    </head>

    <div class="admin-container">
        <div class="header-section">
            <h1>Forge d'une nouvelle Race</h1>
        </div>

        {# Le formulaire est inclus ici via le fichier partagé _form.html.twig #}
        {{ include('race/_form.html.twig') }}

        <div class="footer-actions">
            <a href="{{ path('app_race_index') }}" class="link-back">⬅ Annuler et revenir à la liste</a>
        </div>
    </div>
{% endblock %}
