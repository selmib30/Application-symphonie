{% extends 'base.html.twig' %}

{% block title %}Groupes{% endblock %}

{% block stylesheets %}
<style>
    body { font-family: sans-serif; max-width: 900px; margin: 0 auto; padding: 20px; }
    .filter-bar {
        background: #f8f9fa; border: 1px solid #ddd; border-radius: 8px;
        padding: 14px; margin-bottom: 24px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
    }
    .filter-bar strong { margin-right: 6px; }
    .btn { display: inline-block; padding: 7px 16px; border-radius: 4px; text-decoration: none; font-size: 14px; border: 1px solid transparent; }
    .btn-outline { background: white; border-color: #ccc; color: #333; }
    .btn-active { background: #007bff; color: white; border-color: #007bff; }
    .btn-success-outline { background: white; border-color: #28a745; color: #28a745; }
    .btn-danger-outline { background: white; border-color: #dc3545; color: #dc3545; }

    .party-list { display: flex; flex-direction: column; gap: 12px; }
    .party-card {
        border: 1px solid #ddd; border-radius: 8px; padding: 16px;
        display: flex; justify-content: space-between; align-items: center; background: #fafafa;
    }
    .party-card.full { border-left: 4px solid #dc3545; }
    .party-card.available { border-left: 4px solid #28a745; }
    .party-info h3 { margin: 0 0 4px; }
    .party-info p { margin: 0; color: #555; font-size: 14px; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }
    .badge-full { background: #f8d7da; color: #721c24; }
    .badge-available { background: #d4edda; color: #155724; }
    .results-count { color: #666; font-size: 14px; margin-bottom: 12px; }
</style>
{% endblock %}

{% block body %}
<h1>🛡️ Groupes d'aventuriers</h1>

{# ===== FILTRE DES GROUPES (paramètre GET) ===== #}
<div class="filter-bar">
    <strong>Filtrer :</strong>

    <a href="{{ path('party_index') }}"
       class="btn {% if currentFilter is null %}btn-active{% else %}btn-outline{% endif %}">
        Tous
    </a>

    <a href="{{ path('party_index', {filter: 'available'}) }}"
       class="btn {% if currentFilter == 'available' %}btn-active{% else %}btn-success-outline{% endif %}">
        ✅ Places disponibles
    </a>

    <a href="{{ path('party_index', {filter: 'full'}) }}"
       class="btn {% if currentFilter == 'full' %}btn-active{% else %}btn-danger-outline{% endif %}">
        🔴 Groupes complets
    </a>
</div>

<p class="results-count">{{ parties|length }} groupe{{ parties|length != 1 ? 's' : '' }} trouvé{{ parties|length != 1 ? 's' : '' }}</p>

{% if parties is empty %}
    <p style="color: #666;">Aucun groupe ne correspond à ce filtre.</p>
{% else %}
<div class="party-list">
    {% for party in parties %}
        {% set isFull = party.characters|length >= party.maxSize %}
        <div class="party-card {{ isFull ? 'full' : 'available' }}">
            <div class="party-info">
                <h3>{{ party.name }}</h3>
                <p>
                    {{ party.description }}<br>
                    Membres : {{ party.characters|length }} / {{ party.maxSize }}
                    &nbsp;
                    {% if isFull %}
                        <span class="badge badge-full">🔴 Complet</span>
                    {% else %}
                        <span class="badge badge-available">✅ {{ party.maxSize - party.characters|length }} place{{ (party.maxSize - party.characters|length) > 1 ? 's' : '' }} dispo</span>
                    {% endif %}
                </p>
            </div>
            <a href="{{ path('party_show', {id: party.id}) }}" class="btn btn-outline">Voir →</a>
        </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
