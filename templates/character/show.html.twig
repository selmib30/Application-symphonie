{% extends 'base.html.twig' %}

{% block title %}Personnage{% endblock %}

{% block body %}
    <h1>Détails du Personnage</h1>

    <table class="table">
        <tbody>
        <tr>
            <th>Id</th>
            <td>{{ character.id }}</td>
        </tr>
        <tr>
            <th>Nom</th>
            <td>{{ character.name }}</td>
        </tr>
        <tr>
            <th>Niveau</th>
            <td>{{ character.level }}</td>
        </tr>
        <tr>
            <th>Force</th>
            <td>{{ character.strength }}</td>
        </tr>
        <tr>
            <th>Dextérité</th>
            <td>{{ character.dexterity }}</td>
        </tr>
        <tr>
            <th>Constitution</th>
            <td>{{ character.constitution }}</td>
        </tr>
        <tr>
            <th>Intelligence</th>
            <td>{{ character.intelligence }}</td>
        </tr>
        <tr>
            <th>Sagesse</th>
            <td>{{ character.wisdom }}</td>
        </tr>
        <tr>
            <th>Charisme</th>
            <td>{{ character.charisma }}</td>
        </tr>
        <tr>
            <th>Points de Vie</th>
            <td>{{ character.healthPoints }}</td>
        </tr>
        <tr>
            <th>Image</th>
            <td>{{ character.image }}</td>
        </tr>
        </tbody>
    </table>

    <div class="actions">
        <a href="{{ path('character_index') }}" class="btn btn-secondary">Retour à la liste</a>

        {# Correction : Utilisation du nom de route exact 'character_edit' au lieu de 'app_character_edit' #}
        <a href="{{ path('character_edit', {'id': character.id}) }}" class="btn btn-primary">Modifier</a>

        {{ include('character/_delete_form.html.twig') }}
    </div>


{% endblock %}
