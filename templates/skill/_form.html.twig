{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin_form.css') }}">
{% endblock %}

{{ form_start(form) }}
<div class="forge-form-content">
    {# Symfony injecte ici les classes CSS via le fichier de config ou manuellement #}
