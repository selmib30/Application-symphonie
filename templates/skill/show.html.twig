{% extends 'base.html.twig' %}

{% block title %}Détails de la Compétence - Admin{% endblock %}

{% block stylesheets %}
    {# On charge le CSS spécifique à l'affichage des détails #}
    <link rel="stylesheet" href="{{ asset('styles/admin_show.css') }}">
{% endblock %}

{% block body %}
    <div class="admin-container">
        <div class="header-section">
            <h1>Fiche Compétence : {{ skill.name }}</h1>
        </div>

        <table class="info-table">
            <tbody>
            <tr>
                <th>Identifiant</th>
                <td><strong>#{{ skill.id }}</strong></td>
            </tr>
            <tr>
                <th>Nom de la compétence</th>
                <td>{{ skill.name }}</td>
            </tr>
            <tr>
                <th>Caractéristique parente</th>
                <td><span class="ability-highlight">{{ skill.ability }}</span></td>
            </tr>
            </tbody>
        </table>

        <div class="actions-bar">
            <a href="{{ path('app_skill_index') }}" class="btn-action btn-back">⬅ Retour à la liste</a>
            <a href="{{ path('app_skill_edit', {'id': skill.id}) }}" class="btn-action btn-edit">✍️ Modifier</a>

            <div style="margin-left: auto;">
                {{ include('skill/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
