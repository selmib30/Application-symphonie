{% extends 'base.html.twig' %}

{% block title %}Modifier le Personnage{% endblock %}

{% block body %}
    {% block stylesheets %}
        {# On charge le CSS spécifique à l'édition #}
        <link rel="stylesheet" href="{{ asset('styles/edit.css') }}">
    {% endblock %}
    <div class="admin-container">
        <div class="header-section">
            <h1>Modifier le Personnage</h1>
            <a href="{{ path('character_index') }}" class="btn-back" style="text-decoration: none; color: #4a3728; font-weight: bold;">
                ← Retour à la liste
            </a>
        </div>

        {# Inclusion du formulaire avec le label de bouton mis à jour #}
        {{ include('character/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

        <hr style="border: 0; border-top: 2px solid #e2d1b3; margin: 2em 0;">

        {# Section de danger pour la suppression #}
        <div class="delete-section" style="text-align: right;">
            <p style="color: #9e2a1f; font-size: 0.8rem; font-style: italic; margin-bottom: 10px;">
                Zone de danger : cette action est irréversible.
            </p>
            {{ include('character/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
