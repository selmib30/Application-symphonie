{% extends 'base.html.twig' %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/index.css') }}">
{% endblock %}
{% block title %}Mes Personnages{% endblock %}

{% block body %}
    <div class="admin-container">

        <div class="header-section">
            <h1>Mes Personnages</h1>
            <a href="{{ path('character_new') }}" class="btn-create">
                Créer un nouveau personnage
            </a>
        </div>

        {# ===================== FILTRES ===================== #}
        <div class="filters-section mb-4">
            <form method="get" action="{{ path('character_index') }}" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="name" class="form-control"
                           placeholder="Rechercher par nom" value="{{ filters.name }}">
                </div>

                <div class="col-md-3">
                    <select name="class" class="form-select">
                        <option value="">Toutes les Classes</option>
                        {% for class in classes %}
                            <option value="{{ class.id }}" {% if filters.class == class.id %}selected{% endif %}>
                                {{ class.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-3">
                    <select name="race" class="form-select">
                        <option value="">Toutes les Races</option>
                        {% for race in races %}
                            <option value="{{ race.id }}" {% if filters.race == race.id %}selected{% endif %}>
                                {{ race.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                    <a href="{{ path('character_index') }}" class="btn btn-secondary w-100">Reset</a>
                </div>
            </form>
        </div>

        {# ===================== TABLEAU ===================== #}
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Classe</th>
                    <th>Race</th>
                    <th>Niv</th>
                    <th>PV</th>
                    <th>FOR</th>
                    <th>DEX</th>
                    <th>CON</th>
                    <th>INT</th>
                    <th>SAG</th>
                    <th>CHA</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for character in characters %}
                    <tr>
                        <td>{{ character.id }}</td>
                        <td style="font-weight: bold; color: #9e2a1f;">{{ character.name }}</td>
                        <td>{{ character.characterClass.name }}</td>
                        <td>{{ character.race.name }}</td>
                        <td><span class="ability-badge">{{ character.level }}</span></td>
                        <td>{{ character.healthPoints }}</td>
                        <td>{{ character.strength }}</td>
                        <td>{{ character.dexterity }}</td>
                        <td>{{ character.constitution }}</td>
                        <td>{{ character.intelligence }}</td>
                        <td>{{ character.wisdom }}</td>
                        <td>{{ character.charisma }}</td>
                        <td class="actions-cell">
                            <a href="{{ path('character_show', {'id': character.id}) }}">Voir</a>
                            <a href="{{ path('character_edit', {'id': character.id}) }}">Modifier</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="13" class="empty-msg">
                            Aucun personnage trouvé dans le grimoire.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
