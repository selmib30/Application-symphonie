{% extends 'base.html.twig' %}

{% block title %}Liste des Personnages{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Mes Personnages</h1>
            <a href="{{ path('character_new') }}" class="btn btn-primary">Créer un nouveau personnage</a>
        </div>

        <table class="table table-hover">
            <thead class="table-dark">
            <tr>
                <th>Avatar</th>
                <th>Nom</th>
                <th>Race</th>
                <th>Classe</th>
                <th>Niveau</th>
                <th>Points de Vie</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for character in characters %}
                <tr>
                    <td>
                        {# Affichage de l'URL externe stockée dans character.image #}
                        {% if character.image %}
                            <img src="{{ character.image }}"
                                 alt="Avatar de {{ character.name }}"
                                 style="width: 50px; height: 50px; object-fit: cover; border-radius: 50%; border: 1px solid #ddd;">
                        {% else %}
                            <div style="width: 50px; height: 50px; background-color: #eee; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: #999;">
                                N/A
                            </div>
                        {% endif %}
                    </td>
                    <td><strong>{{ character.name }}</strong></td>
                    <td>{{ character.race ? character.race.name : 'Non définie' }}</td>
                    <td>{{ character.characterClass ? character.characterClass.name : 'Non définie' }}</td>
                    <td>{{ character.level }}</td>
                    <td>{{ character.healthPoints }} HP</td>
                    <td>
                        <div class="btn-group" role="group">
                            {# Correction du lien vers la fiche (Route character_show) #}
                            <a href="{{ path('character_show', {'id': character.id}) }}" class="btn btn-sm btn-outline-info">Voir</a>

                            {# Lien vers l'édition (Route character_edit) #}
                            <a href="{{ path('character_edit', {'id': character.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>

                            {# Formulaire de suppression (inclut le jeton CSRF) #}
                            {{ include('character/_delete_form.html.twig') }}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center">Vous n'avez pas encore créé de personnage.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
