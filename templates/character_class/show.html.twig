{% extends 'base.html.twig' %}

{% block title %}Détails de la Classe - Admin{% endblock %}

{% block stylesheets %}
    {# On réutilise le CSS de consultation pour la cohérence #}
    <link rel="stylesheet" href="{{ asset('styles/admin_show.css') }}">
{% endblock %}

{% block body %}
    <div class="admin-container">
        <div class="header-section">
            <h1>Fiche de Classe : {{ character_class.name }}</h1>
        </div>

        <table class="info-table">
            <tbody>
            <tr>
                <th>Identifiant de Guilde</th>
                <td><strong>#{{ character_class.id }}</strong></td>
            </tr>
            <tr>
                <th>Nom de la Classe</th>
                <td>{{ character_class.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td><p class="description-text">{{ character_class.description }}</p></td>
            </tr>
            <tr>
                <th>Compétences associées</th>
                <td>
                    {% if character_class.skills is not empty %}
                        {% for skill in character_class.skills %}
                            <span class="ability-badge">{{ skill.name }}</span>
                        {% endfor %}
                    {% else %}
                        <span style="color: #999; font-style: italic;">Aucune compétence</span>
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Dé de Vie</th>
                <td><span class="dice-highlight">🎲 d{{ character_class.healthDice }}</span></td>
            </tr>
            </tbody>
        </table>

        <div class="actions-bar">
            <a href="{{ path('app_character_class_index') }}" class="btn-action btn-back">⬅ Retour à la liste</a>
            <a href="{{ path('app_character_class_edit', {'id': character_class.id}) }}" class="btn-action btn-edit">✍️ Modifier la Classe</a>

            <div style="margin-left: auto;">
                {# Intégration du bouton de suppression stylisé #}
                {{ include('character_class/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
