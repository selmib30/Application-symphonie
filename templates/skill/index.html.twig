{% extends 'base.html.twig' %}

{% block title %}Grimoire des Compétences - Admin{% endblock %}

{% block stylesheets %}
    {# On charge le CSS des listes admin #}
    <link rel="stylesheet" href="{{ asset('styles/admin_index.css') }}">
{% endblock %}

{% block body %}
    <div class="admin-container">
        <div class="header-section">
            <h1>Grimoire des Compétences</h1>
            <a href="{{ path('app_skill_new') }}" class="btn-create">📜 Nouvelle Compétence</a>
        </div>

        <table class="data-table">
            <thead>
            <tr>
                <th style="width: 60px;">ID</th>
                <th>Nom</th>
                <th style="width: 200px;">Caractéristique liée</th>
                <th style="width: 180px;">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for skill in skills %}
                <tr>
                    <td><strong>#{{ skill.id }}</strong></td>
                    <td><span style="font-weight: bold; color: #333;">{{ skill.name }}</span></td>
                    <td>
                        <span class="ability-badge">{{ skill.ability }}</span>
                    </td>
                    <td class="actions-cell">
                        <a href="{{ path('app_skill_show', {'id': skill.id}) }}">👁️ Voir</a>
                        <a href="{{ path('app_skill_edit', {'id': skill.id}) }}">✍️ Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="empty-msg">Le grimoire est vide pour le moment.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
